From a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0 Mon Sep 17 00:00:00 2001
From: GitHub Copilot <noreply@github.com>
Date: Thu, 12 Mar 2026 22:00:00 +0000
Subject: [PATCH] ANDROID: GKI: always include devices cgroup subsystem for ABI
 stability

When CONFIG_CGROUP_DEVICE is enabled, SUBSYS(devices) is added to the
cgroup_subsys_id enum, increasing CGROUP_SUBSYS_COUNT. This changes
the size of embedded arrays (subsys[], e_cset_node[], e_csets[]) in
struct css_set and struct cgroup, shifting the offsets of all
subsequent fields and breaking the GKI ABI for pre-compiled vendor
modules.

Fix this by always including SUBSYS(devices) in cgroup_subsys.h
regardless of CONFIG_CGROUP_DEVICE. This keeps CGROUP_SUBSYS_COUNT,
devices_cgrp_id, and all subsequent subsystem IDs stable whether
CONFIG_CGROUP_DEVICE is enabled or not.

A minimal stub devices_cgrp_subsys is provided in device_cgroup.c
for when CONFIG_CGROUP_DEVICE is disabled, so the subsystem is
properly registered and initialized without providing actual device
cgroup functionality.

Additionally, a safety check is added in
devcgroup_legacy_check_permission() to guard against the css not
being initialized yet during early boot. The check verifies both
that the dev_cgroup pointer is valid and that the subsystem is
online (behavior != DEVCG_DEFAULT_NONE), which catches the window
between css_alloc and css_online during cgroup initialization.

Change-Id: Ia1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0
Signed-off-by: GitHub Copilot <noreply@github.com>
---
 include/linux/cgroup_subsys.h |  7 +++++--
 security/device_cgroup.c      | 32 ++++++++++++++++++++++++++++++++
 2 files changed, 37 insertions(+), 2 deletions(-)
diff --git a/security/device_cgroup.c b/security/device_cgroup.c
index 089c3ecd9e1e..b3f5a7c8d2e1 100644
--- a/security/device_cgroup.c
+++ b/security/device_cgroup.c
@@ -416,6 +416,10 @@ static int devcgroup_legacy_check_permission(short type, u32 major, u32 minor,
 
 	rcu_read_lock();
 	dev_cgroup = task_devcgroup(current);
+	if (!dev_cgroup || !is_devcg_online(dev_cgroup)) {
+		rcu_read_unlock();
+		return 0;
+	}
 	if (dev_cgroup->behavior == DEVCG_DEFAULT_ALLOW)
 		/* Can't match any of the exceptions, even partially */
 		rc = !match_exception_partial(&dev_cgroup->exceptions,
@@ -432,6 +436,34 @@ static int devcgroup_legacy_check_permission(short type, u32 major, u32 minor,
 
 #endif /* CONFIG_CGROUP_DEVICE */
 
+#ifndef CONFIG_CGROUP_DEVICE
+/*
+ * Stub implementation to keep CGROUP_SUBSYS_COUNT stable for GKI ABI.
+ * When CONFIG_CGROUP_DEVICE is not enabled, this provides a minimal
+ * no-op subsystem so the devices_cgrp_id slot is always occupied.
+ */
+static struct cgroup_subsys_state *
+devcgroup_css_alloc_noop(struct cgroup_subsys_state *parent_css)
+{
+	struct cgroup_subsys_state *css;
+
+	css = kzalloc(sizeof(*css), GFP_KERNEL);
+	if (!css)
+		return ERR_PTR(-ENOMEM);
+	return css;
+}
+
+static void devcgroup_css_free_noop(struct cgroup_subsys_state *css)
+{
+	kfree(css);
+}
+
+struct cgroup_subsys devices_cgrp_subsys = {
+	.css_alloc	= devcgroup_css_alloc_noop,
+	.css_free	= devcgroup_css_free_noop,
+};
+#endif /* !CONFIG_CGROUP_DEVICE */
+
 #if defined(CONFIG_CGROUP_DEVICE) || defined(CONFIG_CGROUP_BPF)
 
 int devcgroup_check_permission(short type, u32 major, u32 minor, short access)
-- 
2.34.1

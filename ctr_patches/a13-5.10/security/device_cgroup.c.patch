From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: GitHub Copilot <noreply@github.com>
Date: Sun, 1 Jun 2026 13:00:00 +0000
Subject: [PATCH] ANDROID: GKI: fix device cgroup for ABI-stable unconditional SUBSYS

Two changes to support making SUBSYS(devices) unconditional:

1. Add NULL safety check in devcgroup_legacy_check_permission() to
   guard against the css not being initialized yet during early boot,
   between css_alloc and css_online.

2. Add a no-op stub devices_cgrp_subsys for when CONFIG_CGROUP_DEVICE
   is disabled. This is required because cgroup_subsys.h now always
   includes SUBSYS(devices), so the kernel always needs
   devices_cgrp_subsys to be defined.

Change-Id: I0000000000000000000000000000000000000002
Signed-off-by: GitHub Copilot <noreply@github.com>
---
 security/device_cgroup.c | 38 ++++++++++++++++++++++++++++++++++++++
 1 file changed, 38 insertions(+)

diff --git a/security/device_cgroup.c b/security/device_cgroup.c
--- a/security/device_cgroup.c
+++ b/security/device_cgroup.c
@@ -838,6 +838,10 @@ static int devcgroup_legacy_check_permission(short type, u32 major, u32 minor,
 
 rcu_read_lock();
 dev_cgroup = task_devcgroup(current);
+	if (!dev_cgroup || !is_devcg_online(dev_cgroup)) {
+		rcu_read_unlock();
+		return 0;
+	}
 if (dev_cgroup->behavior == DEVCG_DEFAULT_ALLOW)
 /* Can't match any of the exceptions, even partially */
 rc = !match_exception_partial(&dev_cgroup->exceptions,
@@ -856,6 +860,34 @@ static int devcgroup_legacy_check_permission(short type, u32 major, u32 minor,
 
 #endif /* CONFIG_CGROUP_DEVICE */
 
+#ifndef CONFIG_CGROUP_DEVICE
+/*
+ * Stub implementation to keep CGROUP_SUBSYS_COUNT stable for GKI ABI
+ * compatibility. When CONFIG_CGROUP_DEVICE is not enabled, provide a
+ * minimal no-op subsystem so the devices_cgrp_id slot is always occupied.
+ */
+static struct cgroup_subsys_state *
+devcgroup_css_alloc_noop(struct cgroup_subsys_state *parent_css)
+{
+	struct cgroup_subsys_state *css;
+
+	css = kzalloc(sizeof(*css), GFP_KERNEL);
+	if (!css)
+		return ERR_PTR(-ENOMEM);
+	return css;
+}
+
+static void devcgroup_css_free_noop(struct cgroup_subsys_state *css)
+{
+	kfree(css);
+}
+
+struct cgroup_subsys devices_cgrp_subsys = {
+	.css_alloc	= devcgroup_css_alloc_noop,
+	.css_free	= devcgroup_css_free_noop,
+};
+#endif /* !CONFIG_CGROUP_DEVICE */
+
 #if defined(CONFIG_CGROUP_DEVICE) || defined(CONFIG_CGROUP_BPF)
 
 int devcgroup_check_permission(short type, u32 major, u32 minor, short access)
-- 
2.34.1
